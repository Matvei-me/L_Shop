{
  "openapi": "3.0.3",
  "info": {
    "title": "L_Shop API",
    "description": "Лабораторный API магазина. Авторизация — cookie `sessionToken` (HttpOnly, JWT). Защищённые ручки требуют залогиниться через POST /api/auth/register или /api/auth/login.",
    "version": "1.0.0"
  },
  "servers": [{ "url": "http://localhost:3000", "description": "локально" }],
  "tags": [
    { "name": "auth", "description": "Регистрация, вход, выход" },
    { "name": "profile", "description": "Текущий пользователь" },
    { "name": "products", "description": "Каталог (доступно без входа)" },
    { "name": "cart", "description": "Корзина (только с cookie)" },
    { "name": "delivery", "description": "Заказы / доставка (только с cookie)" }
  ],
  "components": {
    "securitySchemes": {
      "cookieAuth": {
        "type": "apiKey",
        "in": "cookie",
        "name": "sessionToken"
      }
    },
    "schemas": {
      "ApiSuccess": {
        "type": "object",
        "properties": {
          "success": { "type": "boolean", "example": true },
          "data": { "description": "полезная нагрузка" },
          "message": { "type": "string" }
        }
      },
      "RegisterBody": {
        "type": "object",
        "required": ["name", "email", "login", "phone", "password"],
        "properties": {
          "name": { "type": "string" },
          "email": { "type": "string", "format": "email" },
          "login": { "type": "string" },
          "phone": { "type": "string" },
          "password": { "type": "string" }
        }
      },
      "LoginBody": {
        "type": "object",
        "required": ["email", "password"],
        "properties": {
          "email": { "type": "string" },
          "password": { "type": "string" }
        }
      },
      "UserIdData": {
        "type": "object",
        "properties": {
          "userId": { "type": "string", "format": "uuid" }
        }
      },
      "UserProfile": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "email": { "type": "string" },
          "login": { "type": "string" },
          "phone": { "type": "string" }
        }
      },
      "Product": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "description": { "type": "string" },
          "price": { "type": "number" },
          "category": { "type": "string" },
          "available": { "type": "boolean" }
        }
      },
      "CartItem": {
        "type": "object",
        "properties": {
          "productId": { "type": "string" },
          "quantity": { "type": "integer", "minimum": 1 }
        }
      },
      "AddCartBody": {
        "type": "object",
        "required": ["productId"],
        "properties": {
          "productId": { "type": "string" },
          "quantity": { "type": "integer", "minimum": 1, "default": 1 }
        }
      },
      "PatchCartBody": {
        "type": "object",
        "required": ["quantity"],
        "properties": {
          "quantity": { "type": "integer", "minimum": 1 }
        }
      },
      "DeliveryBody": {
        "type": "object",
        "required": ["address", "phone", "email", "payment"],
        "properties": {
          "address": { "type": "string" },
          "phone": { "type": "string" },
          "email": { "type": "string", "format": "email" },
          "payment": { "type": "string", "description": "например card, cash, online" }
        }
      },
      "Order": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "userId": { "type": "string" },
          "address": { "type": "string" },
          "phone": { "type": "string" },
          "email": { "type": "string" },
          "payment": { "type": "string" },
          "items": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "productId": { "type": "string" },
                "quantity": { "type": "integer" }
              }
            }
          },
          "createdAt": { "type": "string", "format": "date-time" }
        }
      },
      "ErrorMessage": {
        "type": "object",
        "properties": {
          "message": { "type": "string" }
        }
      }
    }
  },
  "paths": {
    "/api/auth/register": {
      "post": {
        "tags": ["auth"],
        "summary": "Регистрация",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/RegisterBody" }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Создан пользователь, установлена cookie sessionToken",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": { "type": "boolean" },
                    "data": { "$ref": "#/components/schemas/UserIdData" }
                  }
                }
              }
            }
          },
          "500": {
            "description": "Ошибка",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorMessage" }
              }
            }
          }
        }
      }
    },
    "/api/auth/login": {
      "post": {
        "tags": ["auth"],
        "summary": "Вход",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/LoginBody" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Успех, cookie sessionToken",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": { "type": "boolean" },
                    "data": { "$ref": "#/components/schemas/UserIdData" }
                  }
                }
              }
            }
          },
          "500": {
            "description": "Ошибка",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorMessage" }
              }
            }
          }
        }
      }
    },
    "/api/auth/logout": {
      "post": {
        "tags": ["auth"],
        "summary": "Выход (очистка cookie)",
        "responses": {
          "200": {
            "description": "Ок",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": { "success": { "type": "boolean" } }
                }
              }
            }
          }
        }
      }
    },
    "/api/profile": {
      "get": {
        "tags": ["profile"],
        "summary": "Профиль текущего пользователя",
        "security": [{ "cookieAuth": [] }],
        "responses": {
          "200": {
            "description": "Данные без пароля",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": { "type": "boolean" },
                    "data": { "$ref": "#/components/schemas/UserProfile" }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Нет cookie / невалидный токен"
          },
          "404": {
            "description": "Пользователь не найден"
          }
        }
      }
    },
    "/api/products": {
      "get": {
        "tags": ["products"],
        "summary": "Список товаров",
        "parameters": [
          {
            "name": "search",
            "in": "query",
            "schema": { "type": "string" },
            "description": "поиск по name и description"
          },
          {
            "name": "sort",
            "in": "query",
            "schema": { "type": "string", "enum": ["price_asc", "price_desc"] }
          },
          {
            "name": "category",
            "in": "query",
            "schema": { "type": "string" }
          },
          {
            "name": "available",
            "in": "query",
            "schema": { "type": "string", "enum": ["true", "false"] }
          }
        ],
        "responses": {
          "200": {
            "description": "Массив товаров",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": { "type": "boolean" },
                    "data": {
                      "type": "array",
                      "items": { "$ref": "#/components/schemas/Product" }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/cart": {
      "get": {
        "tags": ["cart"],
        "summary": "Текущая корзина",
        "security": [{ "cookieAuth": [] }],
        "responses": {
          "200": {
            "description": "Позиции корзины",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": { "type": "boolean" },
                    "data": {
                      "type": "array",
                      "items": { "$ref": "#/components/schemas/CartItem" }
                    }
                  }
                }
              }
            }
          },
          "401": { "description": "Не авторизован" }
        }
      }
    },
    "/api/cart/items": {
      "post": {
        "tags": ["cart"],
        "summary": "Добавить товар в корзину",
        "security": [{ "cookieAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/AddCartBody" }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Обновлённая корзина",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": { "type": "boolean" },
                    "data": {
                      "type": "array",
                      "items": { "$ref": "#/components/schemas/CartItem" }
                    }
                  }
                }
              }
            }
          },
          "401": { "description": "Не авторизован" }
        }
      }
    },
    "/api/cart/items/{productId}": {
      "patch": {
        "tags": ["cart"],
        "summary": "Изменить количество",
        "security": [{ "cookieAuth": [] }],
        "parameters": [
          {
            "name": "productId",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/PatchCartBody" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Обновлённая корзина",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": { "type": "boolean" },
                    "data": {
                      "type": "array",
                      "items": { "$ref": "#/components/schemas/CartItem" }
                    }
                  }
                }
              }
            }
          },
          "401": { "description": "Не авторизован" }
        }
      },
      "delete": {
        "tags": ["cart"],
        "summary": "Удалить позицию из корзины",
        "security": [{ "cookieAuth": [] }],
        "parameters": [
          {
            "name": "productId",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Обновлённая корзина",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": { "type": "boolean" },
                    "data": {
                      "type": "array",
                      "items": { "$ref": "#/components/schemas/CartItem" }
                    }
                  }
                }
              }
            }
          },
          "401": { "description": "Не авторизован" }
        }
      }
    },
    "/api/delivery": {
      "get": {
        "tags": ["delivery"],
        "summary": "Мои заказы",
        "security": [{ "cookieAuth": [] }],
        "responses": {
          "200": {
            "description": "Список заказов",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": { "type": "boolean" },
                    "data": {
                      "type": "array",
                      "items": { "$ref": "#/components/schemas/Order" }
                    }
                  }
                }
              }
            }
          },
          "401": { "description": "Не авторизован" }
        }
      },
      "post": {
        "tags": ["delivery"],
        "summary": "Оформить доставку (после успеха корзина очищается)",
        "security": [{ "cookieAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/DeliveryBody" }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Заказ создан",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": { "type": "boolean" },
                    "data": { "$ref": "#/components/schemas/Order" }
                  }
                }
              }
            }
          },
          "400": { "description": "Не все поля" },
          "401": { "description": "Не авторизован" }
        }
      }
    }
  }
}
